__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ipynb_checkpoints/
*.egg-info/

# Coverage / reports
coverage/
.nyc_output/
playwright-report/
test-results/

# Logs
*.log
logs/
*.log.*

# IDE / OS
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# Local data / dev artifacts
postgres-data/
ml-models/
mlflow.db
*.zip
*.bak
logs.txt
logs_full.txt
hashes.json
hashes.txt
full_hashes.txt
