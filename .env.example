# ========================
# Smart HR System - Environment Variables
# ========================
# Copy this to .env and fill in real values.
# NEVER commit the actual .env file.

# === DATABASE CONFIGURATION ===
DB_HOST=postgres
DB_PORT=5432
DB_USER=hr
DB_PASSWORD=CHANGE_ME
DB_NAME=hr_system
DATABASE_URL=postgresql://hr:CHANGE_ME@postgres:5432/hr_system

# === POSTGRES CONTAINER INIT (must match DB_* above) ===
POSTGRES_USER=hr
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=hr_system
DB_POOL_MAX=20
DB_POOL_MIN=5

# === BACKEND CONFIGURATION ===
NODE_ENV=development
BACKEND_PORT=3000
BACKEND_HOST=0.0.0.0
JWT_SECRET=CHANGE_ME_USE_STRONG_RANDOM_STRING
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=CHANGE_ME_USE_DIFFERENT_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# === FRONTEND CONFIGURATION ===
FRONTEND_PORT=3001

# === ML SERVICE CONFIGURATION ===
ML_SERVICE_PORT=8000
ML_MODELS_PATH=/app/models
ML_LOG_LEVEL=INFO

# === ERPNext INTEGRATION (optional) ===
ERPNEXT_URL=http://erpnext:8000
ERPNEXT_API_KEY=CHANGE_ME
ERPNEXT_API_SECRET=CHANGE_ME
ERPNEXT_COMPANY_NAME=your-company
ERPNEXT_SYNC_INTERVAL=3600
ERPNEXT_MAX_RETRIES=3

# === REDIS CACHE ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=300

# === NGINX CONFIGURATION ===
NGINX_PORT=80

# === EMAIL CONFIGURATION ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=noreply@your-domain.com

# === FILE UPLOAD ===
MAX_FILE_SIZE=10485760
UPLOAD_PATH=/app/uploads

# === SECURITY ===
CORS_ORIGIN=http://localhost:3001
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100