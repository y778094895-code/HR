# App
APP_ENV=dev
LOG_LEVEL=INFO

# Postgres (for platform DB + optionally MLflow backend store)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hr_intelligence
DB_USER=postgres
DB_PASSWORD=postgres

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=attrition_survival_v1

# Model
MODEL_NAME=attrition_survival
MODEL_VERSION=0.1.0
