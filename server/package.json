{
    "name": "smart-hr-server",
    "version": "0.0.1",
    "description": "Smart HR Performance Management System Backend",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "tsc",
        "format": "prettier --write \"{api,data,services,shared,tests,scripts}/**/*.ts\"",
        "start": "ts-node server.ts",
        "start:dev": "nodemon --watch \"./**/*.ts\" --ignore dist --exec \"npx ts-node\" server.ts",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/server.js",
        "lint": "eslint . --ext .ts --ignore-pattern dist --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "test:integration": "jest tests/integration/full_system.test.ts --forceExit --detectOpenHandles",
        "generate": "drizzle-kit generate:pg",
        "migrate": "drizzle-kit push:pg --config=drizzle.config.ts",
        "migrate:versioned": "ts-node scripts/migrate.ts",
        "migrate:help": "node -e \"console.log('Use npm run migrate:versioned for safe SQL migrations. Avoid push in prod.')\"",
        "seed": "node scripts/seed-admin.js"
    },
    "dependencies": {
        "@nestjs/common": "^10.0.0",
        "@nestjs/config": "^3.1.1",
        "@nestjs/core": "^10.0.0",
        "@nestjs/jwt": "^10.2.0",
        "@nestjs/passport": "^10.0.3",
        "@nestjs/platform-express": "^10.0.0",
        "@nestjs/swagger": "^7.1.1",
        "amqplib": "^0.10.3",
        "axios": "^1.6.5",
        "bcryptjs": "^2.4.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.0",
        "consul": "^1.2.0",
        "cors": "^2.8.6",
        "dotenv": "^17.2.3",
        "drizzle-orm": "^0.29.3",
        "helmet": "^8.1.0",
        "inversify": "^6.0.1",
        "inversify-express-utils": "^6.5.0",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "pg": "^8.11.3",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "uuid": "^9.0.1",
        "ws": "^8.19.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.0.0",
        "@nestjs/schematics": "^10.0.0",
        "@nestjs/testing": "^10.0.0",
        "@types/amqplib": "^0.10.1",
        "@types/bcryptjs": "^2.4.6",
        "@types/consul": "^0.40.0",
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.17",
        "@types/jest": "^29.5.2",
        "@types/node": "^20.3.1",
        "@types/passport-jwt": "^3.0.13",
        "@types/passport-local": "^1.0.38",
        "@types/pg": "^8.10.9",
        "@types/supertest": "^2.0.12",
        "@types/uuid": "^9.0.7",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "drizzle-kit": "^0.20.13",
        "eslint": "^8.42.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-prettier": "^5.0.0",
        "jest": "^29.5.0",
        "nodemon": "^3.1.11",
        "prettier": "^3.0.0",
        "source-map-support": "^0.5.21",
        "supertest": "^6.3.3",
        "ts-jest": "^29.1.0",
        "ts-loader": "^9.4.3",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.1.3"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": ".",
        "testRegex": ".*\\.(spec|test)\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
