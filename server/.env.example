# Server local development environment
# Copy to .env and fill in values. Never commit .env.

PORT=3000
SERVICE_NAME=employee-service
NODE_ENV=development

# Database
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=hr
DB_PASSWORD=CHANGE_ME
DB_NAME=hr_system

# Queue
RABBITMQ_URL=amqp://localhost:5672

# Redis
REDIS_URL=redis://localhost:6379

# Consul (optional — service registry)
CONSUL_HOST=localhost
CONSUL_PORT=8500
SERVICE_ADDRESS=localhost

# Security
JWT_SECRET=CHANGE_ME_USE_STRONG_RANDOM_STRING

# ML Service
ML_SERVICE_URL=http://localhost:8000

# HR AI Layer (optional)
HR_AI_LAYER_ENABLED=false
HR_AI_LAYER_URL=http://localhost:8001
HR_AI_LAYER_TIMEOUT_MS=5000
